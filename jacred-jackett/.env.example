APP_PORT=9117
HEALTHCHECK_PORT=9117
TZ=UTC
UMASK=0027

# Путь к вашему config.yml (относительно docker-compose.yml)
CONFIG_PATH=./config.yml

# Настройки базы данных
DB_HOST=db
DB_PORT=5432
DB_NAME=jacred
DB_USER=jacred
DB_PASSWORD=jacred

# Полная строка подключения (если не задана, собирается из DB_* выше)
# DB_CONNECTION=Host=db;Port=5432;Database=jacred;Username=jacred;Password=jacred;Timeout=30;CommandTimeout=60;

# Тег/имя образа приложения при локальной сборке
IMAGE_NAME=jacred:local
